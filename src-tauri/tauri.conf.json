{
  "productName": "Cthulu Lab",
  "version": "0.1.0",
  "identifier": "com.cthululab.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cthulu Lab",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' http://localhost:4000 https://api.notion.com https://api.linear.app http://34.100.130.60:8080; style-src 'self' 'unsafe-inline'; img-src 'self' data:; frame-src http://34.100.130.60:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
